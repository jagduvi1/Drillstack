# ── Secrets (loaded by docker-compose from .env) ────
JWT_SECRET=change-this-to-a-random-string
MEILI_MASTER_KEY=masterkey-dev-change-in-prod

# ── AI completion provider ───────────────────────────
# Supported: openai | anthropic | ollama
AI_PROVIDER=anthropic
AI_API_KEY=your-api-key-here
AI_MODEL=claude-sonnet-4-6
# Optional: use a stronger model for tactic board generation from drills
# TACTIC_AI_MODEL=claude-opus-4-6
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=

# ── Voyage AI — embeddings ───────────────────────────
# Get your key at https://dash.voyageai.com/
VOYAGE_API_KEY=your-voyage-api-key-here
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-4-lite
EMBEDDING_DIMENSIONS=1024

# ── Super Admin ──────────────────────────────────────
# The account with this email gets access to /superadmin
# SUPER_ADMIN_EMAIL=superadmin@yourdomain.com
# SUPER_ADMIN_IPS=1.2.3.4,5.6.7.8
