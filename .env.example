# ── MongoDB ──────────────────────────────────────────
MONGO_USER=admin
MONGO_PASS=changeme
MONGO_URI=mongodb://admin:changeme@mongo:27017/training_bank?authSource=admin

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-string

# ── Qdrant (vector search) ───────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=training_bank

# ── Meilisearch (keyword search, feature-flagged) ────
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=masterkey
ENABLE_MEILISEARCH=true

# ── AI / Embedding provider ─────────────────────────
# Supported: openai | anthropic | ollama | custom
AI_PROVIDER=openai
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4o

EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development
